# Copy to .env and fill in. Only the key for your chosen provider is required.

# --- Model selection -------------------------------------------------------
# provider:model  (e.g. openai:gpt-4o-mini, anthropic:claude-3-5-sonnet-latest,
# google_genai:gemini-1.5-pro). Install the matching provider package to switch.
RFP_MODEL=openai:gpt-4o-mini
RFP_TEMPERATURE=0.2

# --- Provider API keys -----------------------------------------------------
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# GOOGLE_API_KEY=...

# --- Optional: LangSmith tracing ------------------------------------------
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=...
# LANGSMITH_PROJECT=procurement-rfp-agent
